{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rulesage.dev/schemas/node.json",
  "title": "Node Definition",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "ir": {
        "$ref": "#/$defs/Ir"
      },
      "desc": {
        "type": "string"
      },
      "parameters": {
        "type": "object",
        "additionalProperties": {
          "$ref": "#/$defs/ParamType"
        }
      }
    },
    "required": ["ir", "desc", "parameters"]
  },
  "$defs": {
    "Ir": {
      "type": "string",
      "pattern": "^[a-zA-Z-][a-zA-Z0-9-]*$"
    },
    "ParamType": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "$type": {
              "const": "leaf"
            }
          },
          "required": ["$type"]
        }, {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "$type": {
              "const": "node"
            },
            "node": {
              "$ref": "#/$defs/Ir"
            }
          },
          "required": ["$type", "node"]
        }, {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "$type": {
              "const": "array"
            },
            "arr": {
              "$ref": "#/$defs/ParamType"
            }
          },
          "required": ["$type", "arr"]
        }
      ]
    }
  }
}